{
  "manifest_version": 3,
  "name": "LeetCode Notebook Sync",
  "version": "1.2",
  "description": "Auto-sync LeetCode AC submissions to your notebook via local Ollama analysis",
  "permissions": ["storage", "scripting", "tabs", "webNavigation"],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://leetcode.cn/*",
    "http://localhost:11434/*",
    "http://localhost:3000/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html" }
}